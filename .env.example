# ---- Required ----------------------------------------------------------------
# One or more secret bearer tokens (comma-separated) that MCP clients must send
# as 'Authorization: Bearer <token>' to reach this server. Generate something
# long and random, e.g. `openssl rand -hex 32`.
MCP_AUTH_TOKEN=replace-with-a-long-random-secret

# ---- Mealie connection -------------------------------------------------------
# Default Mealie base URL. Clients may override per request with the
# 'X-Mealie-Url' header; if every client always sends that header you may leave
# this blank.
MEALIE_BASE_URL=https://mealie.example.com

# ---- Optional tuning ---------------------------------------------------------
# Read-only by default. Set to false to also expose write tools (create/update/
# delete). The Mealie token's own permissions still apply regardless.
MEALIE_READONLY=true
# Outbound request timeout (seconds) when calling Mealie.
MEALIE_TIMEOUT=30
# Set to false to skip TLS verification (e.g. self-signed Mealie cert).
MEALIE_VERIFY_SSL=true
# Path the Streamable HTTP endpoint is served on.
MCP_PATH=/mcp
# uvicorn log level: critical | error | warning | info | debug | trace
MCP_LOG_LEVEL=info
# Set to true to log a masked diagnostic for every request reaching the auth
# gate (Authorization header present/absent, scheme, token length + a SHA-256
# fingerprint vs. the configured tokens). Use it to troubleshoot 401s; the token
# itself is never logged. Leave off in normal operation.
MCP_AUTH_DEBUG=false
